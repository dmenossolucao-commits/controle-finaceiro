rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to verify admin permissions
    function isAdmin() {
      return request.auth != null && (
        (
          exists(/databases/$(database)/documents/admins/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.profile == 'admin' &&
          get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.status == 'active'
        ) || (
          request.auth.token.email == 'ericacostapsicologa7@gmail.com' ||
          request.auth.token.email == 'd-briciod2@hotmail.com' ||
          request.auth.token.email == 'admin@ericacostapsi.com.br' ||
          request.auth.token.email == 'dmenossolucao@gmail.com'
        )
      );
    }

    // Admins list: read is open (to allow checking first admin existence), but write/update/delete requires being an active admin, OR if the first-time setup hasn't been performed yet
    match /admins/{document} {
      allow read: if true;
      allow write: if isAdmin() || !exists(/databases/$(database)/documents/admins/ericacostapsicologa7@gmail.com);
    }
    
    // Site content: read by anyone, write only by authenticated admins
    match /site_content/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Blog posts: read by anyone, write only by authenticated admins
    match /blog_posts/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Lead messages: anyone can submit (create), but only authenticated admins can read/update/delete
    match /leads_messages/{document} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
    
    // Appointments: anyone can create or view individual appointment details.
    // Anonymous patients can list (needed for booking and searching theirs) and update (only for rescheduling or cancelling).
    // Deleting requires admin auth.
    match /appointments/{document} {
      allow create, get, list: if true;
      allow update: if isAdmin() || (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'date', 'timeSlot'])
      );
      allow delete: if isAdmin();
    }
    
    // Blocked slots: read by anyone (for calendar availability), write only by authenticated admins
    match /blocked_slots/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Clinical Patients: strictly private, only authenticated admins can read/write/delete
    match /patients/{document} {
      allow read, write: if isAdmin();
    }
    
    // Patient clinical records: strictly private, only authenticated admins can read/write/delete
    match /patient_records/{document} {
      allow read, write: if isAdmin();
    }

    // Patient documents: strictly private, only authenticated admins can read/write/delete
    match /patient_documents/{document} {
      allow read, write: if isAdmin();
    }

    // Financial transactions: strictly private, only authenticated admins can read/write/delete
    match /financial_transactions/{document} {
      allow read, write: if isAdmin();
    }

    // Receipts: strictly private, only authenticated admins can read/write/delete
    match /receipts/{document} {
      allow read, write: if isAdmin();
    }

    // Pix Config: anyone can read, write only by authenticated admins
    match /pix_config/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Backup logs: strictly private, only authenticated admins can read/write/delete
    match /backup_logs/{document} {
      allow read, write: if isAdmin();
    }

    // Backup settings: strictly private, only authenticated admins can read/write/delete
    match /backup_settings/{document} {
      allow read, write: if isAdmin();
    }

    // Security Audit logs: strictly private, only authenticated admins can read/write/delete
    match /audit_logs/{document} {
      allow read, write: if isAdmin();
    }

    // Document versions: strictly private, only authenticated admins can read/write/delete
    match /document_versions/{document} {
      allow read, write: if isAdmin();
    }

    // Trash bin: strictly private, only authenticated admins can read/write/delete
    match /trash_bin/{document} {
      allow read, write: if isAdmin();
    }

    // Login attempts: anyone can read/write to allow lockout security tracking before authenticating
    match /login_attempts/{document} {
      allow read, write: if true;
    }
  }
}
